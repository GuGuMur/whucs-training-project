{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug From Login",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:8080/login",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": [
        "<node_internals>/**",
        "${workspaceFolder}/frontend/node_modules/**"
      ]
    },
    {
